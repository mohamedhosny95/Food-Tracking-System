# Telegram — get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Google Gemini — FREE, get from aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Notion — get from notion.so/my-integrations
NOTION_API_KEY=
# These are filled in automatically by setup_notion.py / migrate_notion.py
NOTION_FOOD_DB_ID=
NOTION_DAILY_DB_ID=
NOTION_RESTAURANTS_DB_ID=
NOTION_SAVED_MEALS_DB_ID=
NOTION_PARENT_PAGE_ID=

# Daily macro & hydration goals (used by /summary progress bars)
DAILY_CALORIES_GOAL=2000
DAILY_PROTEIN_GOAL=150
DAILY_CARBS_GOAL=250
DAILY_FAT_GOAL=65
DAILY_FIBER_GOAL=30
DAILY_WATER_GOAL_ML=2500

# Optional: your Telegram user ID to restrict bot access (get it from @userinfobot)
# Leave empty to allow anyone who finds your bot to use it
ALLOWED_USER_IDS=
